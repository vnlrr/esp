-- Matcha ESP Library (text-only)
-- Fully customizable from outside the source. Load it, edit ESP.Settings or pass
-- per-tracker options. Draws stacked text tags (name, distance, and any custom
-- tags you add) anchored to a world object. No boxes/tracers.
--
--   local ESP = loadstring(game:HttpGet("<your-url>"))()
--   ESP.Settings.Distance = true
--   local t = ESP.NewTracker(workspace.SomeModel, { Name = "Enemy", Color = Color3.fromRGB(255,0,0) })
--   t:AddText("HP", "HP: 100", Color3.fromRGB(0,255,0))   -- extra tag
--   t:ChangeText("HP", "HP: 42")
--   t:Destroy()

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer

local ESP = {}
ESP.__index = ESP

ESP.Trackers = {}

ESP.Settings = {
    Enabled = true,

    Name = true,
    Distance = true,

    NameAnchor = "top",      -- "top" | "middle" | "bottom" (relative to the object)
    Spacing = 2,

    Font = (Drawing.Fonts and (Drawing.Fonts.UI or Drawing.Fonts.System or Drawing.Fonts.SystemBold)) or 0,
    TextSize = 14,
    TextOutline = true,

    MaxDistance = 0,         -- 0 = unlimited (studs)

    Color = Color3.fromRGB(255, 255, 255),
    NameColor = nil,
    DistanceColor = Color3.fromRGB(200, 200, 200),
}

local BasePartTypes = {
    Part = "BasePart",
    MeshPart = "BasePart",
    UnionOperation = "BasePart",
    CornerWedgePart = "BasePart",
    WedgePart = "BasePart",
    TrussPart = "BasePart",
    Seat = "BasePart",
    VehicleSeat = "BasePart",
    SpawnLocation = "BasePart",
    Model = "Model",
    Actor = "Model",
}

local function classifyObject(object)
    if typeof(object) ~= "Instance" then return nil end
    return BasePartTypes[object.ClassName]
end

local function resolveModelPart(model)
    local common = { "HumanoidRootPart", "Root", "RootPart", "Torso", "UpperTorso", "Core", "Head" }
    local children = model:GetChildren()

    for _, name in ipairs(common) do
        for _, child in ipairs(children) do
            if string.lower(child.Name) == string.lower(name) and BasePartTypes[child.ClassName] == "BasePart" then
                return child
            end
        end
    end

    if model.ClassName == "Model" and model.PrimaryPart then
        return model.PrimaryPart
    end

    local largest, maxVol = nil, 0
    for _, child in ipairs(model:GetDescendants()) do
        if BasePartTypes[child.ClassName] == "BasePart" then
            local s = child.Size
            local vol = s.X * s.Y * s.Z
            if vol > maxVol then
                maxVol = vol
                largest = child
            end
        end
    end
    return largest
end

local function newDrawing(kind)
    local ok, d = pcall(Drawing.new, kind)
    if ok and d then return d end
    return nil
end

local function optOf(self, key)
    local v = self.Options[key]
    if v ~= nil then return v end
    return ESP.Settings[key]
end

--============================================================
-- Tracker
--============================================================

function ESP.NewTracker(object, options)
    options = options or {}

    local objectType = classifyObject(object)
    if not objectType then
        warn("[ESP] NewTracker expects a BasePart or Model, got: " .. tostring(object))
        return nil
    end

    local rawObject = object
    local part = object
    if objectType == "Model" then
        part = resolveModelPart(object)
        if not part then
            warn("[ESP] Model has no valid parts: " .. tostring(object.Name))
            return nil
        end
    end

    local key = part.Address
    if ESP.Trackers[key] then
        return ESP.Trackers[key]
    end

    local self = setmetatable({}, ESP)
    self.RawObject = rawObject
    self.Object = part
    self.ObjectType = objectType
    self.Options = options
    self.Type = options.Type
    self.Name = options.Name or rawObject.Name
    self.Color = options.Color or ESP.Settings.Color
    self.Visible = true
    self.Texts = {}
    self.TextOrder = {}

    self:AddText("Name", self.Name, self.Color)
    self:AddText("Distance", "[0m]", ESP.Settings.DistanceColor, function()
        return "[" .. math.floor(self:_GetDistance()) .. "m]"
    end)

    ESP.Trackers[key] = self
    return self
end

function ESP:AddText(reference, value, color, callback)
    if self.Texts[reference] then return self.Texts[reference] end

    local text = newDrawing("Text")
    if not text then return nil end
    text.Center = true
    text.Outline = optOf(self, "TextOutline")
    local font = optOf(self, "Font")
    if font ~= nil then pcall(function() text.Font = font end) end
    local sz = optOf(self, "TextSize")
    pcall(function() text.Size = sz end)
    pcall(function() text.FontSize = sz end)
    text.Color = color or self.Color or ESP.Settings.Color
    text.Text = (callback and callback()) or value or reference
    text.Visible = false

    local entry = {
        Drawing = text,
        Callback = callback,
        Color = text.Color,
        Show = true,
    }
    self.Texts[reference] = entry
    table.insert(self.TextOrder, reference)
    return entry
end

function ESP:ChangeText(reference, value, color)
    local entry = self.Texts[reference]
    if not entry then return end
    if value ~= nil then entry.Drawing.Text = value end
    if color then
        entry.Drawing.Color = color
        entry.Color = color
    end
end

function ESP:SetTextVisible(reference, state)
    local entry = self.Texts[reference]
    if entry then entry.Show = state end
end

function ESP:RemoveText(reference)
    local entry = self.Texts[reference]
    if not entry then return end
    pcall(function() entry.Drawing:Remove() end)
    self.Texts[reference] = nil
    for i, ref in ipairs(self.TextOrder) do
        if ref == reference then
            table.remove(self.TextOrder, i)
            break
        end
    end
end

function ESP:Set(key, value)
    self.Options[key] = value
end

function ESP:SetColor(color)
    self.Color = color
    self:ChangeText("Name", nil, color)
end

function ESP:SetVisible(state)
    self.Visible = state
end

function ESP:_IsAlive()
    return self.RawObject and self.RawObject:IsDescendantOf(workspace) and true or false
end

function ESP:_Position()
    if self.ObjectType == "Model" then
        local ok, cf = pcall(function() return self.RawObject:GetBoundingBox() end)
        if ok and cf then return cf.Position end
    end
    if self.Object and self.Object.Parent then
        return self.Object.Position
    end
    return nil
end

function ESP:_GetDistance()
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return 0 end
    local pos = self:_Position()
    if not pos then return 0 end
    return (hrp.Position - pos).Magnitude
end

function ESP:_HideAll()
    for _, ref in ipairs(self.TextOrder or {}) do
        local e = self.Texts[ref]
        if e and e.Drawing then e.Drawing.Visible = false end
    end
end

function ESP:_Update()
    if not self:_IsAlive() then
        self:Destroy()
        return
    end

    if not ESP.Settings.Enabled or not self.Visible then
        self:_HideAll()
        return
    end

    local position = self:_Position()
    if not position then
        self:_HideAll()
        return
    end

    local maxDist = optOf(self, "MaxDistance")
    if maxDist and maxDist > 0 then
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp and (hrp.Position - position).Magnitude > maxDist then
            self:_HideAll()
            return
        end
    end

    local screen, onScreen = WorldToScreen(position)
    if not onScreen or not screen then
        self:_HideAll()
        return
    end

    local anchor = optOf(self, "NameAnchor")
    local size = optOf(self, "TextSize")
    local spacing = optOf(self, "Spacing")
    local lineH = size + spacing

    local visible = {}
    for _, ref in ipairs(self.TextOrder) do
        local entry = self.Texts[ref]
        local show = entry.Show ~= false
        if ref == "Name" and not optOf(self, "Name") then show = false end
        if ref == "Distance" and not optOf(self, "Distance") then show = false end
        if entry.Drawing then
            if show then
                visible[#visible + 1] = entry
            else
                entry.Drawing.Visible = false
            end
        end
    end

    local n = #visible
    local baseY
    if anchor == "bottom" then
        baseY = screen.Y + spacing
    elseif anchor == "middle" then
        baseY = screen.Y - (n * lineH) * 0.5
    else
        baseY = screen.Y - spacing - (n * lineH)
    end

    for i, entry in ipairs(visible) do
        local d = entry.Drawing
        d.Center = true
        local font = optOf(self, "Font")
        if font ~= nil then pcall(function() d.Font = font end) end
        pcall(function() d.Size = size end)
        pcall(function() d.FontSize = size end)
        if entry.Callback then d.Text = entry.Callback() end
        d.Position = Vector2.new(screen.X, baseY + (i - 1) * lineH)
        d.Visible = true
    end
end

function ESP:Destroy()
    if self.Object then
        ESP.Trackers[self.Object.Address] = nil
    end
    for _, entry in pairs(self.Texts or {}) do
        pcall(function() entry.Drawing:Remove() end)
    end
    self.Texts = nil
    self.TextOrder = nil
    self.Object = nil
    self.RawObject = nil
    setmetatable(self, nil)
end

--============================================================
-- Library helpers
--============================================================

function ESP.Get(object)
    if typeof(object) ~= "Instance" then return nil end
    local part = object
    if classifyObject(object) == "Model" then
        part = resolveModelPart(object)
    end
    return part and ESP.Trackers[part.Address] or nil
end

function ESP.RemoveType(typeName)
    for _, tracker in pairs(ESP.Trackers) do
        if tracker.Type == typeName then
            tracker:Destroy()
        end
    end
end

function ESP.DestroyAll()
    for _, tracker in pairs(ESP.Trackers) do
        tracker:Destroy()
    end
    ESP.Trackers = {}
end

function ESP.Unload()
    ESP._Running = false
    ESP.DestroyAll()
    _G.ESP = nil
end

if _G.ESP and _G.ESP._Running ~= nil then
    _G.ESP._Running = false
end

ESP._Running = true
task.spawn(function()
    while ESP._Running do
        for _, tracker in pairs(ESP.Trackers) do
            pcall(function() tracker:_Update() end)
        end
        task.wait()
    end
end)

_G.ESP = ESP
return ESP
